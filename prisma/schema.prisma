generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String         @unique
  password      String
  role          String         @default("USER")
  reputation    Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  notifications Notification[] @relation("ReceivedNotifications")
  actedNotifs   Notification[] @relation("ActorNotifications")
  reports       SafetyReport[] @relation("ReportedBy")
  reviewedReports SafetyReport[] @relation("ReviewedBy")
}

model Game {
  id            String        @id @default(cuid())
  title         String
  description   String
  tags          String        @default("[]")
  rating        Float         @default(0)
  downloadCount Int           @default(0)
  coverData     String?
  scanStatus    String        @default("NOT_SCANNED")
  sha256        String?
  fileName      String?
  verifiedAt    DateTime?
  reportCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  fileScans     FileScan[]
  reports       SafetyReport[]
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String
  category    String     @default("General")
  locked      Boolean    @default(false)
  pinned      Boolean    @default(false)
  pinnedUntil DateTime?
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  comments    Comment[]
  likes       Like[]
  notifications Notification[]
  reports     SafetyReport[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  editedAt  DateTime?
  deletedAt DateTime?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  postId    String
  post      Post      @relation(fields: [postId], references: [id])
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  likes     Like[]
  notifications Notification[]
  createdAt DateTime  @default(now())
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id])
  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  recipientId String
  recipient   User     @relation("ReceivedNotifications", fields: [recipientId], references: [id])
  actorId     String
  actor       User     @relation("ActorNotifications", fields: [actorId], references: [id])
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id])
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id])
}

model SafetyReport {
  id          String   @id @default(cuid())
  reason      String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?

  reporterId String
  reporter   User   @relation("ReportedBy", fields: [reporterId], references: [id])

  reviewerId String?
  reviewer   User?  @relation("ReviewedBy", fields: [reviewerId], references: [id])

  gameId String?
  game   Game?  @relation(fields: [gameId], references: [id])

  postId String?
  post   Post?  @relation(fields: [postId], references: [id])
}

model FileScan {
  id         String    @id @default(cuid())
  sha256     String
  fileName   String
  fileSize   Int?
  scanStatus String    @default("QUEUED")
  scanResult String?
  scannedAt  DateTime?
  createdAt  DateTime  @default(now())

  gameId String @unique
  game   Game   @relation(fields: [gameId], references: [id])
}

model PageVisit {
  id        String   @id @default(cuid())
  url       String
  ip        String?
  userId    String?
  userAgent String?
  createdAt DateTime @default(now())
}
